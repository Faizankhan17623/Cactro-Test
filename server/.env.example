# Connection string to your PostgreSQL database. Copy this file to ".env" and
# replace the placeholders below with your own values. Never commit the real .env.
#   Local example:  postgres://USER:PASSWORD@localhost:5432/releasecheck
#   Hosted example: postgres://USER:PASSWORD@HOST:5432/DBNAME  (Render/Neon/Supabase give you one)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/releasecheck

# Port the API listens on.
PORT=5000

# Set to "disable" when connecting to a local Postgres without SSL.
PGSSL=disable
